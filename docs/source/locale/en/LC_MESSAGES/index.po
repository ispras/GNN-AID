msgstr "graph visualization and analysis tools"

#: ../../index.rst:14
msgid "конструктор модели \"без кода\""
msgstr "no-code model building"

#: ../../index.rst:15
msgid "визуализация объяснений решения модели"
msgstr "visualization of models explanations"

#: ../../index.rst:16
