msgid "``full_name`` - кортеж из имен подпапок, длины не менее 2"
msgstr ""

#: ../../user_guide/datasets.rst:208
msgid "``init_kwargs`` - словарь параметров для конструктора"
msgstr ""

#: ../../user_guide/datasets.rst:211
msgid "DatasetVarConfig"
msgstr ""

#: ../../user_guide/datasets.rst:213
msgid "Определяет как будут построена вариативная часть датасета."
msgstr ""

#: ../../user_guide/datasets.rst:215
msgid "``features`` - объект ``FeatureConfig``"
msgstr ""

