" пути ``ptg-library-graphs/<domain>/<group>/<name>``, где"
msgstr ""

#: ../../user_guide/datasets.rst:91
msgid ""
"``domain`` - ``single-graph`` или ``multiple-graphs`` в зависимости от "
"числа графов в датасете"
msgstr ""

