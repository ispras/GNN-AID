msgid ""
"config to define where to get raw files and initialization parameters. "
"Can be :class:`~data_structures.configs.DatasetConfig` object or "
":class:`~data_structures.configs.ConfigPattern` with dictionary."
msgstr ""

#: datasets.gen_dataset.GeneralDataset.root_dir:1 of
msgid "Dataset root directory with folder 'raw/' and metainfo file."
msgstr ""

#: datasets.gen_dataset.GeneralDataset.raw_dir:1 of
